{
    "name": "Vibe .NET10 + Angular",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash",
                "files.eol": "\n"
            },
            "extensions": [
                "ms-dotnettools.csharp",
                "angular.ng-template",
                "eamodio.gitlens",
                "visualstudioexptteam.vscodeintellicode"
            ],
            "forwardPorts": [5000, 5001, 4200],
            "postCreateCommand": "dotnet --list-sdks && npm install -g @angular/cli",
            "remoteUser": "vscode"
        }
    }
}